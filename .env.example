# --- KI ---
# Gemini = GRATIS (Free Tier). Treibt Tests + Entwürfe.
GEMINI_API_KEY=
# Anthropic (Claude) = BEZAHLT. Nur für den Voll-Autopilot nötig. Leer lassen = Gemini-Fallback.
ANTHROPIC_API_KEY=
LLM_AUTOPILOT_PROVIDER=claude

# --- LinkedIn offizielle API (nur fürs Posting) ---
# Aus dem LinkedIn Developer Portal (App mit "Share on LinkedIn"-Produkt)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Deine Person-URN, z.B. urn:li:person:xxxxx  (einmalig via /v2/userinfo holen)
LINKEDIN_PERSON_URN=

# --- Telegram-Steuerung ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Pfade ---
SESSION_DIR=./.session
DB_PATH=./data.db

# --- Browser ---
# embedded (Standard) = kein Fenster, Live-Ansicht im Dashboard. visible = echtes Fenster.
# BROWSER_MODE=visible
