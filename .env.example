# Am einfachsten richtest du alles über den Setup-Assistenten ein: Tool starten und im
# Browser http://localhost:4321 öffnen – der Assistent fragt Gemini-Key, Profil und LinkedIn ab.
# Diese Datei ist die manuelle Alternative.

# --- KI (PFLICHT ist nur Gemini) ---
# Gemini = GRATIS (Free Tier). Treibt Tests + Entwürfe. NUR DAS ist zwingend nötig.
GEMINI_API_KEY=
# Anthropic (Claude) = BEZAHLT. Nur für den Voll-Autopilot nötig. Leer lassen = Gemini-Fallback.
ANTHROPIC_API_KEY=
LLM_AUTOPILOT_PROVIDER=claude

# --- LinkedIn offizielle API (OPTIONAL, NUR fürs eigene Posten) ---
# Komplett weglassen ist okay: Vernetzen, DMs, Kommentare & Likes laufen ohne das (über die
# Browser-Session). Ohne diese Keys werden nur "eigene Posts über die API" deaktiviert.
# Aus dem LinkedIn Developer Portal (App mit "Share on LinkedIn"-Produkt)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Deine Person-URN, z.B. urn:li:person:xxxxx  (einmalig via /v2/userinfo holen)
LINKEDIN_PERSON_URN=

# --- Telegram-Steuerung ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Pfade ---
SESSION_DIR=./.session
DB_PATH=./data.db

# --- Browser ---
# embedded (Standard) = kein Fenster, Live-Ansicht im Dashboard. visible = echtes Fenster.
# BROWSER_MODE=visible

# Notnagel: faellt Gemini aus, springt Claude ein (kostet Geld, meldet sich vorher
# per Telegram). false = Bot steht lieber still als Geld auszugeben.
# LLM_FALLBACK=false
